#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIENTS_DIR="${ROOT_DIR}/clients"
TEMPLATE_COMPOSE="${ROOT_DIR}/templates/docker-compose.client.yml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

usage() {
  cat <<USAGE
ERPNext/Frappe Docker Client Manager
Usage:
  ./client list
  ./client create <client> [erpnext_version] [http_port] [site_name]
  ./client up <client>
  ./client down <client>
  ./client restart <client>
  ./client status [client]
  ./client logs <client> [service]
  ./client shell <client>
  ./client site-create <client>
  ./client app-list <client>
  ./client app-get <client> <repo_url> [branch]
  ./client app-install <client> <app_name>
  ./client app-get-install <client> <repo_url> [branch] [app_name]
  ./client restore <client> <dump.sql|dump.sql.gz> [db_name]
  ./client url <client>
USAGE
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || log_err "Commande requise introuvable: $1"
}

rand_hex() {
  local len="${1:-24}"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex "$len"
  else
    tr -dc 'a-f0-9' </dev/urandom | head -c "$((len * 2))"
  fi
}

is_valid_name() {
  [[ "$1" =~ ^[a-z0-9][a-z0-9-]{1,40}$ ]]
}

client_dir() {
  echo "${CLIENTS_DIR}/$1"
}

env_file() {
  echo "$(client_dir "$1")/.env"
}

compose_file() {
  echo "$(client_dir "$1")/docker-compose.yml"
}

ensure_client_exists() {
  local client="$1"
  [[ -f "$(env_file "$client")" && -f "$(compose_file "$client")" ]] || log_err "Client '${client}' introuvable."
}

get_env() {
  local client="$1"
  local key="$2"
  grep -E "^${key}=" "$(env_file "$client")" | tail -n1 | cut -d= -f2-
}

dc() {
  local client="$1"
  shift
  ensure_client_exists "$client"
  local project
  project="$(get_env "$client" PROJECT)"
  docker compose -f "$(compose_file "$client")" --env-file "$(env_file "$client")" -p "$project" "$@"
}

bench_exec() {
  local client="$1"
  local cmd="$2"
  dc "$client" up -d db redis-cache redis-queue backend >/dev/null 2>&1
  dc "$client" exec -T backend bash -lc "$cmd"
}

reload_after_app_install() {
  local client="$1"
  local site="$2"
  bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" clear-cache"
  dc "$client" restart backend frontend websocket >/dev/null 2>&1
}

installed_apps_from_db() {
  local client="$1"
  local db_name="$2"
  local db_root_password
  db_root_password="$(get_env "$client" DB_ROOT_PASSWORD)"
  dc "$client" exec -T db mariadb -N -s -uroot -p"$db_root_password" "$db_name" -e "SELECT app_name FROM \`tabInstalled Applications\`;" 2>/dev/null || true
}

is_app_importable() {
  local client="$1"
  local app="$2"
  dc "$client" up -d db redis-cache redis-queue backend >/dev/null 2>&1
  dc "$client" exec -T backend bash -lc "cd /home/frappe/frappe-bench && env/bin/python -c 'import ${app}'" >/dev/null 2>&1
}

repair_apps_after_restore() {
  local client="$1"
  local db_name="$2"
  local apps_dir
  apps_dir="$(client_dir "$client")/data/apps"
  local site
  site="$(get_env "$client" SITE_NAME)"

  local repaired=0
  local missing_apps=()
  local app
  while IFS= read -r app; do
    [[ -z "$app" ]] && continue
    if is_app_importable "$client" "$app"; then
      continue
    fi

    if [[ -d "${apps_dir}/${app}" ]]; then
      log_warn "App '${app}' absente de l'env Python, réparation depuis data/apps/${app}..."
      dc "$client" exec -T backend bash -lc "cd /home/frappe/frappe-bench && env/bin/pip install -e apps/${app}"
      dc "$client" exec -T backend bash -lc "cd /home/frappe/frappe-bench && grep -qx '${app}' sites/apps.txt || echo '${app}' >> sites/apps.txt"
      repaired=1
      if ! is_app_importable "$client" "$app"; then
        missing_apps+=("$app")
      fi
    else
      missing_apps+=("$app")
    fi
  done < <(installed_apps_from_db "$client" "$db_name")

  if (( repaired == 1 )); then
    dc "$client" restart backend frontend websocket >/dev/null 2>&1
  fi

  if (( ${#missing_apps[@]} > 0 )); then
    log_error_list="$(printf '%s, ' "${missing_apps[@]}")"
    log_error_list="${log_error_list%, }"
    log_err "Restauration OK mais apps manquantes dans le code: ${log_error_list}. Installe-les via ./client app-get-install puis relance."
  fi

  bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" clear-cache"
}

get_json_value() {
  local json_file="$1"
  local key="$2"
  if command -v jq >/dev/null 2>&1; then
    jq -r --arg k "$key" '.[$k] // empty' "$json_file"
  else
    python3 - "$json_file" "$key" <<'PY'
import json
import sys
path = sys.argv[1]
key = sys.argv[2]
with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)
print(data.get(key, ""))
PY
  fi
}

site_db_name() {
  local client="$1"
  local site
  site="$(get_env "$client" SITE_NAME)"
  local site_config
  site_config="$(client_dir "$client")/data/sites/${site}/site_config.json"
  [[ -f "$site_config" ]] || log_err "site_config.json introuvable: ${site_config}"
  local db_name
  db_name="$(get_json_value "$site_config" "db_name")"
  [[ -n "$db_name" ]] || log_err "db_name absent dans ${site_config}"
  echo "$db_name"
}

is_ssh_repo_url() {
  local repo_url="$1"
  [[ "$repo_url" =~ ^git@ ]] || [[ "$repo_url" =~ ^ssh:// ]]
}

repo_name_from_url() {
  local repo_url="$1"
  local repo_name
  repo_name="$(basename "$repo_url")"
  repo_name="${repo_name%.git}"
  echo "$repo_name"
}

host_clone_and_copy_app() {
  local client="$1"
  local repo_url="$2"
  local branch="${3:-}"

  need_cmd git
  dc "$client" up -d db redis-cache redis-queue backend >/dev/null 2>&1

  local tmp_dir
  tmp_dir="$(mktemp -d)"
  local repo_name
  repo_name="$(repo_name_from_url "$repo_url")"
  local repo_dir="${tmp_dir}/${repo_name}"

  log_info "Clone sur l'hôte (SSH): ${repo_url}"
  if [[ -n "$branch" ]]; then
    git clone --branch "$branch" "$repo_url" "$repo_dir"
  else
    git clone "$repo_url" "$repo_dir"
  fi

  local backend_id
  backend_id="$(dc "$client" ps -q backend | head -n1)"
  [[ -n "$backend_id" ]] || log_err "Container backend introuvable pour ${client}."

  log_info "Import de l'app dans le bench du conteneur..."
  bench_exec "$client" "rm -rf /tmp/${repo_name} /home/frappe/frappe-bench/apps/${repo_name}"
  docker cp "$repo_dir" "${backend_id}:/tmp/${repo_name}"
  bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets /tmp/${repo_name}"
  bench_exec "$client" "cd /home/frappe/frappe-bench && rm -rf /tmp/${repo_name}"

  rm -r "$tmp_dir"
  log_ok "App ${repo_name} récupérée dans le bench."
}

next_port() {
  local start=8080
  local used
  used="$(grep -R "^HTTP_PORT=" "${CLIENTS_DIR}" 2>/dev/null | cut -d= -f2 | sort -n | uniq || true)"
  local p="$start"
  while true; do
    if ! grep -qx "$p" <<<"$used"; then
      echo "$p"
      return
    fi
    p=$((p + 1))
  done
}

cmd="${1:-}"
client="${2:-}"

case "$cmd" in
  create)
    need_cmd docker
    [[ -n "$client" ]] || log_err "Nom client requis."
    is_valid_name "$client" || log_err "Nom invalide. Utilise: lettres minuscules, chiffres, tirets."

    cdir="$(client_dir "$client")"
    [[ ! -d "$cdir" ]] || log_err "Le client '${client}' existe déjà."

    erpnext_version="${3:-v16.5.0}"
    http_port="${4:-$(next_port)}"
    site_name="${5:-${client}.local}"

    mkdir -p "$cdir"/data/{apps,db,logs,sites,redis-queue}
    cp "$TEMPLATE_COMPOSE" "$cdir/docker-compose.yml"

    db_root_password="$(rand_hex 12)"
    admin_password="$(rand_hex 12)"

    cat >"$cdir/.env" <<EOFENV
PROJECT=erpnext-${client}
CLIENT_NAME=${client}
ERPNEXT_VERSION=${erpnext_version}
HTTP_PORT=${http_port}
SITE_NAME=${site_name}
DB_ROOT_PASSWORD=${db_root_password}
ADMIN_PASSWORD=${admin_password}
EOFENV

    cat >"$cdir/README.md" <<EOFCLIENT
# ${client}

- URL locale: http://localhost:${http_port}
- Site ERPNext: ${site_name}
- Version ERPNext image: ${erpnext_version}

Commandes:
- ../../client up ${client}
- ../../client site-create ${client}
- ../../client logs ${client}
EOFCLIENT

    log_ok "Client '${client}' créé (${erpnext_version}, port ${http_port})."
    log_info "Démarrage: ./client up ${client}"
    log_info "Initialisation du site: ./client site-create ${client}"
    ;;

  list)
    printf "%-22s %-12s %-8s %-28s %-10s\n" "CLIENT" "VERSION" "PORT" "SITE" "STATUS"
    printf "%-22s %-12s %-8s %-28s %-10s\n" "----------------------" "------------" "--------" "----------------------------" "----------"
    shopt -s nullglob
    for d in "${CLIENTS_DIR}"/*; do
      [[ -d "$d" && -f "$d/.env" ]] || continue
      cname="$(basename "$d")"
      version="$(grep '^ERPNEXT_VERSION=' "$d/.env" | cut -d= -f2)"
      port="$(grep '^HTTP_PORT=' "$d/.env" | cut -d= -f2)"
      site="$(grep '^SITE_NAME=' "$d/.env" | cut -d= -f2)"
      project="$(grep '^PROJECT=' "$d/.env" | cut -d= -f2)"
      status="$(docker compose -f "$d/docker-compose.yml" --env-file "$d/.env" -p "$project" ps --format '{{.State}}' 2>/dev/null | head -n1 || true)"
      [[ -n "$status" ]] || status="stopped"
      printf "%-22s %-12s %-8s %-28s %-10s\n" "$cname" "$version" "$port" "$site" "$status"
    done
    ;;

  up)
    [[ -n "$client" ]] || usage
    log_info "Démarrage de ${client}..."
    dc "$client" up -d
    log_ok "Client ${client} démarré."
    ;;

  down)
    [[ -n "$client" ]] || usage
    log_info "Arrêt de ${client}..."
    dc "$client" down
    log_ok "Client ${client} arrêté."
    ;;

  restart)
    [[ -n "$client" ]] || usage
    log_info "Redémarrage de ${client}..."
    dc "$client" restart
    log_ok "Client ${client} redémarré."
    ;;

  status)
    if [[ -n "$client" ]]; then
      dc "$client" ps
    else
      "$0" list
    fi
    ;;

  logs)
    [[ -n "$client" ]] || usage
    service="${3:-}"
    if [[ -n "$service" ]]; then
      dc "$client" logs -f "$service"
    else
      dc "$client" logs -f
    fi
    ;;

  shell)
    [[ -n "$client" ]] || usage
    dc "$client" exec backend bash
    ;;

  site-create)
    [[ -n "$client" ]] || usage
    log_info "Création/initialisation du site ERPNext pour ${client}..."
    dc "$client" --profile init run --rm create-site
    log_ok "Site créé pour ${client}."
    ;;

  app-list)
    [[ -n "$client" ]] || usage
    site="$(get_env "$client" SITE_NAME)"
    log_info "Apps disponibles dans le bench (${client})..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && ls -1 apps"
    echo
    log_info "Apps installées sur le site ${site}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" list-apps"
    ;;

  app-get)
    [[ -n "$client" ]] || usage
    repo_url="${3:-}"
    branch="${4:-}"
    [[ -n "$repo_url" ]] || log_err "Usage: ./client app-get <client> <repo_url> [branch]"
    log_info "Récupération de l'app depuis ${repo_url}..."
    if is_ssh_repo_url "$repo_url"; then
      host_clone_and_copy_app "$client" "$repo_url" "$branch"
    elif [[ -n "$branch" ]]; then
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets --branch \"$branch\" \"$repo_url\""
    else
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets \"$repo_url\""
    fi
    log_ok "App récupérée."
    ;;

  app-install)
    [[ -n "$client" ]] || usage
    app_name="${3:-}"
    [[ -n "$app_name" ]] || log_err "Usage: ./client app-install <client> <app_name>"
    site="$(get_env "$client" SITE_NAME)"
    log_info "Installation de l'app ${app_name} sur ${site}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" install-app \"$app_name\""
    reload_after_app_install "$client" "$site"
    log_ok "App ${app_name} installée sur ${site}."
    ;;

  app-get-install)
    [[ -n "$client" ]] || usage
    repo_url="${3:-}"
    branch="${4:-}"
    app_name="${5:-}"
    [[ -n "$repo_url" ]] || log_err "Usage: ./client app-get-install <client> <repo_url> [branch] [app_name]"

    if is_ssh_repo_url "$repo_url"; then
      host_clone_and_copy_app "$client" "$repo_url" "$branch"
    elif [[ -n "$branch" ]]; then
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets --branch \"$branch\" \"$repo_url\""
    else
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets \"$repo_url\""
    fi

    if [[ -z "$app_name" ]]; then
      app_name="$(basename "$repo_url")"
      app_name="${app_name%.git}"
    fi

    site="$(get_env "$client" SITE_NAME)"
    log_info "Installation de l'app ${app_name} sur ${site}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" install-app \"$app_name\""
    reload_after_app_install "$client" "$site"
    log_ok "App ${app_name} récupérée et installée."
    ;;

  restore)
    [[ -n "$client" ]] || usage
    dump_file="${3:-}"
    db_name="${4:-}"
    [[ -n "$dump_file" ]] || log_err "Usage: ./client restore <client> <dump.sql|dump.sql.gz> [db_name]"
    [[ -f "$dump_file" ]] || log_err "Dump introuvable: ${dump_file}"

    if [[ -z "$db_name" ]]; then
      db_name="$(site_db_name "$client")"
    fi

    db_root_password="$(get_env "$client" DB_ROOT_PASSWORD)"
    [[ -n "$db_root_password" ]] || log_err "DB_ROOT_PASSWORD manquant dans $(env_file "$client")"

    dc "$client" up -d db >/dev/null 2>&1
    log_info "Préparation de la base '${db_name}'..."
    dc "$client" exec -T db mariadb -uroot -p"$db_root_password" -e "CREATE DATABASE IF NOT EXISTS \`${db_name}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"

    log_info "Restauration du dump '${dump_file}' dans '${db_name}'..."
    if [[ "$dump_file" == *.gz ]]; then
      gzip -dc "$dump_file" | dc "$client" exec -T db mariadb -uroot -p"$db_root_password" "$db_name"
    else
      cat "$dump_file" | dc "$client" exec -T db mariadb -uroot -p"$db_root_password" "$db_name"
    fi

    repair_apps_after_restore "$client" "$db_name"
    log_ok "Restauration terminée pour '${client}' (DB: ${db_name})."
    ;;

  url)
    [[ -n "$client" ]] || usage
    ensure_client_exists "$client"
    port="$(get_env "$client" HTTP_PORT)"
    site="$(get_env "$client" SITE_NAME)"
    echo "Local:  http://localhost:${port}"
    echo "Site:   ${site}"
    ;;

  *)
    usage
    ;;
esac
