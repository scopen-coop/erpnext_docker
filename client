#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIENTS_DIR="${ROOT_DIR}/clients"
TEMPLATE_COMPOSE="${ROOT_DIR}/templates/docker-compose.client.yml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

usage() {
  cat <<USAGE
ERPNext/Frappe Docker Client Manager (dev)
Usage:
  ./client list
  ./client create <client> [frappe_branch] [http_port] [site_name]
  ./client host-map <client>
  ./client up <client>
  ./client down <client>
  ./client delete <client>
  ./client restart <client>
  ./client status [client]
  ./client logs <client> [service]
  ./client shell <client>
  ./client site-create <client>
  ./client restore <client> <backup_sql_gz> [site_name]
  ./client app-list <client>
  ./client app-get <client> <repo_url> [branch]
  ./client app-install <client> <app_name>
  ./client app-get-install <client> <repo_url> [branch] [app_name]
  ./client bench-update <client> [bench_update_args...]
  ./client fix-perms <client>
  ./client url <client>
USAGE
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || log_err "Commande requise introuvable: $1"
}

rand_hex() {
  local len="${1:-24}"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex "$len"
  else
    tr -dc 'a-f0-9' </dev/urandom | head -c "$((len * 2))"
  fi
}

is_valid_name() {
  [[ "$1" =~ ^[a-z0-9][a-z0-9-]{1,40}$ ]]
}

normalize_frappe_branch() {
  local input="$1"

  if [[ "$input" =~ ^version-[0-9]+$ ]]; then
    echo "$input"
    return
  fi

  if [[ "$input" =~ ^v?([0-9]+)(\..*)?$ ]]; then
    echo "version-${BASH_REMATCH[1]}"
    return
  fi

  if [[ "$input" == "develop" ]]; then
    echo "develop"
    return
  fi

  echo "$input"
}

client_dir() {
  echo "${CLIENTS_DIR}/$1"
}

env_file() {
  echo "$(client_dir "$1")/.env"
}

compose_file() {
  echo "$(client_dir "$1")/docker-compose.yml"
}

ensure_client_exists() {
  local client="$1"
  [[ -f "$(env_file "$client")" && -f "$(compose_file "$client")" ]] || log_err "Client '${client}' introuvable."
}

get_env() {
  local client="$1"
  local key="$2"
  grep -E "^${key}=" "$(env_file "$client")" | tail -n1 | cut -d= -f2-
}

dc() {
  local client="$1"
  shift
  ensure_client_exists "$client"
  local project
  project="$(get_env "$client" PROJECT)"
  docker compose -f "$(compose_file "$client")" --env-file "$(env_file "$client")" -p "$project" "$@"
}

seed_apps_from_git() {
  local client="$1"
  need_cmd git

  local cdir apps_dir branch
  cdir="$(client_dir "$client")"
  apps_dir="${cdir}/data/apps"
  branch="$(get_env "$client" FRAPPE_BRANCH)"

  mkdir -p "$apps_dir"

  if [[ ! -d "${apps_dir}/frappe/.git" ]]; then
    log_info "Clone frappe (${branch}) dans data/apps..."
    rm -rf "${apps_dir}/frappe"
    git clone --depth 1 --branch "$branch" https://github.com/frappe/frappe.git "${apps_dir}/frappe"
  fi

  if [[ ! -d "${apps_dir}/erpnext/.git" ]]; then
    log_info "Clone erpnext (${branch}) dans data/apps..."
    rm -rf "${apps_dir}/erpnext"
    git clone --depth 1 --branch "$branch" https://github.com/frappe/erpnext.git "${apps_dir}/erpnext"
  fi
}

fix_permissions() {
  local client="$1"
  local cdir
  cdir="$(client_dir "$client")"
  mkdir -p "$cdir"/data/{apps,sites,logs}
  chmod -R u+rwX,g+rwX "$cdir"/data/apps "$cdir"/data/sites "$cdir"/data/logs 2>/dev/null || true
}

sync_ssh_to_backend() {
  local client="$1"
  local ssh_dir="${HOME}/.ssh"
  local backend_cid
  local tmp_ssh

  [[ -d "$ssh_dir" ]] || return 0
  backend_cid="$(dc "$client" ps -q backend | head -n1)"
  [[ -n "$backend_cid" ]] || return 0

  tmp_ssh="$(mktemp -d)"
  cp -a "${ssh_dir}/." "${tmp_ssh}/" 2>/dev/null || true
  find "$tmp_ssh" -type s -delete 2>/dev/null || true

  dc "$client" exec -T backend bash -lc "mkdir -p /home/frappe/.ssh && chmod 700 /home/frappe/.ssh"
  docker cp "${tmp_ssh}/." "${backend_cid}:/home/frappe/.ssh/"
  dc "$client" exec -T backend bash -lc "chmod 700 /home/frappe/.ssh && find /home/frappe/.ssh -type f -exec chmod 600 {} + && touch /home/frappe/.ssh/known_hosts && ssh-keyscan -H github.com >> /home/frappe/.ssh/known_hosts 2>/dev/null || true && chmod 644 /home/frappe/.ssh/known_hosts"
  rm -rf "$tmp_ssh"
}

bench_exec() {
  local client="$1"
  local cmd="$2"

  seed_apps_from_git "$client"
  fix_permissions "$client"
  dc "$client" up -d db redis-cache redis-queue redis-socketio backend websocket queue-short queue-long scheduler >/dev/null 2>&1
  sync_ssh_to_backend "$client"
  dc "$client" exec -T backend bash -lc "cd /home/frappe/frappe-bench && mkdir -p sites && ls -1 apps > sites/apps.txt && ln -snf sites/apps.txt apps.txt && if [[ -d apps/erpnext ]]; then env/bin/pip install -q -e apps/erpnext; fi && env/bin/pip install -q -e apps/frappe && for app in \$(ls -1 apps); do if [[ \"\$app\" != \"frappe\" && \"\$app\" != \"erpnext\" ]] && [[ -f \"apps/\$app/pyproject.toml\" || -f \"apps/\$app/setup.py\" ]]; then env/bin/pip install -q -e \"apps/\$app\"; fi; done && $cmd"
}

create_site_if_needed() {
  local client="$1"
  local site_name admin_password db_root_password
  site_name="$(get_env "$client" SITE_NAME)"
  admin_password="$(get_env "$client" ADMIN_PASSWORD)"
  db_root_password="$(get_env "$client" DB_ROOT_PASSWORD)"

  log_info "Création/initialisation du site ERPNext pour ${client}..."
  bench_exec "$client" "cd /home/frappe/frappe-bench && if [[ -f \"sites/${site_name}/site_config.json\" ]]; then echo \"Site ${site_name} déjà initialisé.\"; else bench new-site --mariadb-user-host-login-scope='%' --db-host db --db-port 3306 --admin-password='${admin_password}' --db-root-username=root --db-root-password='${db_root_password}' --install-app erpnext --set-default '${site_name}'; fi"
  log_ok "Site prêt pour ${client}."
}

restart_runtime_services() {
  local client="$1"
  local defined_services
  defined_services="$(dc "$client" config --services 2>/dev/null || true)"
  local services=(backend websocket queue-short queue-long scheduler)
  local to_restart=()
  local service

  for service in "${services[@]}"; do
    if grep -qx "$service" <<<"$defined_services"; then
      to_restart+=("$service")
    fi
  done

  if (( ${#to_restart[@]} > 0 )); then
    dc "$client" restart "${to_restart[@]}" >/dev/null 2>&1
  fi

  wait_http_ready "$client"
}

wait_http_ready() {
  local client="$1"
  local port
  local site_name
  local url
  local tmp_body
  local http_code
  local attempts=0
  port="$(get_env "$client" HTTP_PORT)"
  site_name="$(get_env "$client" SITE_NAME)"
  url="http://localhost:${port}/api/method/ping"
  local timeout=180
  local elapsed=0

  tmp_body="$(mktemp)"
  while (( elapsed < timeout )); do
    attempts=$((attempts + 1))
    http_code="$(curl -s -m 3 --connect-timeout 1 -H "Host: ${site_name}" -o "$tmp_body" -w "%{http_code}" "$url" 2>/dev/null || true)"

    if grep -q '"message":"pong"' "$tmp_body"; then
      rm -f "$tmp_body"
      return 0
    fi

    if [[ "$http_code" == "404" ]] && grep -q "does not exist" "$tmp_body"; then
      log_info "Backend prêt, mais le site ${site_name} n'est pas encore initialisé."
      rm -f "$tmp_body"
      return 0
    fi

    if (( attempts % 10 == 0 )); then
      log_info "Attente backend (${elapsed}s/${timeout}s)... code=${http_code:-n/a}"
    fi

    sleep 2
    elapsed=$((elapsed + 2))
  done

  rm -f "$tmp_body"
  log_warn "Le backend semble encore en cours de démarrage (timeout ${timeout}s)."
}

ensure_upstream_remotes() {
  local client="$1"
  bench_exec "$client" "cd /home/frappe/frappe-bench/apps && if [[ -d frappe/.git ]]; then git -C frappe remote get-url upstream >/dev/null 2>&1 || git -C frappe remote add upstream https://github.com/frappe/frappe.git; fi && if [[ -d erpnext/.git ]]; then git -C erpnext remote get-url upstream >/dev/null 2>&1 || git -C erpnext remote add upstream https://github.com/frappe/erpnext.git; fi"
}

cleanup_git_locks() {
  local client="$1"
  bench_exec "$client" "cd /home/frappe/frappe-bench/apps && for app in frappe erpnext; do if [[ -d \"\$app/.git\" ]]; then rm -f \"\$app/.git/index.lock\" \"\$app/.git/shallow.lock\" \"\$app/.git/HEAD.lock\" \"\$app/.git/packed-refs.lock\"; fi; done"
}

next_port() {
  local start=8080
  local used
  used="$(grep -R "^HTTP_PORT=" "${CLIENTS_DIR}" 2>/dev/null | cut -d= -f2 | sort -n | uniq || true)"
  local p="$start"
  while true; do
    if ! grep -qx "$p" <<<"$used"; then
      echo "$p"
      return
    fi
    p=$((p + 1))
  done
}

ensure_hosts_mapping() {
  local host_name="$1"
  local ip="${2:-127.0.0.1}"

  [[ -n "$host_name" ]] || return 0

  if awk -v host="$host_name" '
    $1 !~ /^#/ {
      for (i = 2; i <= NF; i++) {
        if ($i == host) found = 1
      }
    }
    END { exit(found ? 0 : 1) }
  ' /etc/hosts 2>/dev/null; then
    log_info "Mapping hosts déjà présent: ${host_name}"
    return 0
  fi

  if [[ -w /etc/hosts ]]; then
    echo "${ip} ${host_name}" >> /etc/hosts
    log_ok "Mapping ajouté dans /etc/hosts: ${host_name} -> ${ip}"
    return 0
  fi

  log_warn "Impossible d'écrire dans /etc/hosts sans droits admin."
  log_info "Ajoute cette ligne:"
  echo "  ${ip} ${host_name}"
  log_info "Commande (Linux): sudo sh -c 'echo \"${ip} ${host_name}\" >> /etc/hosts'"
}

cmd="${1:-}"
client="${2:-}"

case "$cmd" in
  create)
    need_cmd docker
    need_cmd git
    [[ -n "$client" ]] || log_err "Nom client requis."
    is_valid_name "$client" || log_err "Nom invalide. Utilise: lettres minuscules, chiffres, tirets."

    cdir="$(client_dir "$client")"
    [[ ! -d "$cdir" ]] || log_err "Le client '${client}' existe déjà."

    frappe_branch_raw="${3:-version-15}"
    frappe_branch="$(normalize_frappe_branch "$frappe_branch_raw")"
    http_port="${4:-$(next_port)}"
    site_name="${5:-${client}.local}"

    mkdir -p "$cdir"/data/{apps,db,logs,sites,redis-cache,redis-queue,redis-socketio}
    cp "$TEMPLATE_COMPOSE" "$cdir/docker-compose.yml"

    db_root_password="123"
    admin_password="admin"

    cat >"$cdir/.env" <<EOFENV
PROJECT=erpnext-${client}
CLIENT_NAME=${client}
FRAPPE_BRANCH=${frappe_branch}
HTTP_PORT=${http_port}
SITE_NAME=${site_name}
DB_ROOT_PASSWORD=${db_root_password}
ADMIN_PASSWORD=${admin_password}
EOFENV

    cat >"$cdir/README.md" <<EOFCLIENT
# ${client}

- URL locale: http://localhost:${http_port}
- Site ERPNext: ${site_name}
- Branche Frappe/ERPNext: ${frappe_branch}

Commandes:
- ../../client up ${client}
- ../../client site-create ${client}
- ../../client logs ${client}
EOFCLIENT

    seed_apps_from_git "$client"
    fix_permissions "$client"
    ensure_hosts_mapping "$site_name"

    log_info "Démarrage automatique de ${client}..."
    dc "$client" up -d --build --remove-orphans
    create_site_if_needed "$client"
    wait_http_ready "$client"

    log_ok "Client '${client}' créé et initialisé (${frappe_branch}, port ${http_port})."
    ;;

  list)
    printf "%-22s %-14s %-8s %-28s %-10s\n" "CLIENT" "BRANCH" "PORT" "SITE" "STATUS"
    printf "%-22s %-14s %-8s %-28s %-10s\n" "----------------------" "--------------" "--------" "----------------------------" "----------"
    shopt -s nullglob
    for d in "${CLIENTS_DIR}"/*; do
      [[ -d "$d" && -f "$d/.env" ]] || continue
      cname="$(basename "$d")"
      branch="$(grep '^FRAPPE_BRANCH=' "$d/.env" | cut -d= -f2)"
      port="$(grep '^HTTP_PORT=' "$d/.env" | cut -d= -f2)"
      site="$(grep '^SITE_NAME=' "$d/.env" | cut -d= -f2)"
      project="$(grep '^PROJECT=' "$d/.env" | cut -d= -f2)"
      status="$(docker compose -f "$d/docker-compose.yml" --env-file "$d/.env" -p "$project" ps --format '{{.State}}' 2>/dev/null | head -n1 || true)"
      [[ -n "$status" ]] || status="stopped"
      printf "%-22s %-14s %-8s %-28s %-10s\n" "$cname" "$branch" "$port" "$site" "$status"
    done
    ;;

  up)
    [[ -n "$client" ]] || usage
    extra_args=("${@:3}")
    seed_apps_from_git "$client"
    fix_permissions "$client"
    log_info "Build/démarrage de ${client}..."
    dc "$client" up -d --build --remove-orphans "${extra_args[@]}"
    ensure_hosts_mapping "$(get_env "$client" SITE_NAME)"
    wait_http_ready "$client"
    log_ok "Client ${client} démarré."
    ;;

  host-map)
    [[ -n "$client" ]] || usage
    ensure_client_exists "$client"
    ensure_hosts_mapping "$(get_env "$client" SITE_NAME)"
    ;;

  down)
    [[ -n "$client" ]] || usage
    log_info "Arrêt de ${client}..."
    dc "$client" down
    log_ok "Client ${client} arrêté."
    ;;

  delete)
    [[ -n "$client" ]] || usage
    ensure_client_exists "$client"
    cdir="$(client_dir "$client")"
    project="$(get_env "$client" PROJECT)"
    log_info "Suppression du client ${client} (containers + volumes + fichiers)..."
    docker compose -f "$(compose_file "$client")" --env-file "$(env_file "$client")" -p "$project" down -v --remove-orphans >/dev/null 2>&1 || true
    rm -rf "$cdir"
    log_ok "Client ${client} supprimé."
    ;;

  restart)
    [[ -n "$client" ]] || usage
    log_info "Redémarrage de ${client}..."
    dc "$client" restart
    log_ok "Client ${client} redémarré."
    ;;

  status)
    if [[ -n "$client" ]]; then
      dc "$client" ps
    else
      "$0" list
    fi
    ;;

  logs)
    [[ -n "$client" ]] || usage
    service="${3:-}"
    if [[ -n "$service" ]]; then
      dc "$client" logs -f "$service"
    else
      dc "$client" logs -f
    fi
    ;;

  shell)
    [[ -n "$client" ]] || usage
    dc "$client" exec backend bash
    ;;

  site-create)
    [[ -n "$client" ]] || usage
    seed_apps_from_git "$client"
    fix_permissions "$client"
    create_site_if_needed "$client"
    ;;

  restore)
    [[ -n "$client" ]] || usage
    backup_src="${3:-}"
    site_name="${4:-}"
    [[ -n "$backup_src" ]] || log_err "Usage: ./client restore <client> <backup_sql_gz> [site_name]"
    [[ -f "$backup_src" ]] || log_err "Backup introuvable: $backup_src"
    [[ "$backup_src" == *.sql.gz ]] || log_warn "Le fichier ne finit pas par .sql.gz (on continue)."
    need_cmd jq

    if [[ -z "$site_name" ]]; then
      site_name="$(get_env "$client" SITE_NAME)"
    fi

    seed_apps_from_git "$client"
    fix_permissions "$client"
    dc "$client" up -d db redis-cache redis-queue redis-socketio backend websocket queue-short queue-long scheduler >/dev/null 2>&1
    sync_ssh_to_backend "$client"

    cdir="$(client_dir "$client")"
    site_backups_dir="${cdir}/data/sites/${site_name}/private/backups"
    mkdir -p "$site_backups_dir"
    cp "$backup_src" "${site_backups_dir}/data.sql.gz"
    chmod 664 "${site_backups_dir}/data.sql.gz" || true

    db_root_password="$(get_env "$client" DB_ROOT_PASSWORD)"
    log_info "Restauration SQL sur ${site_name}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"${site_name}\" restore --mariadb-root-username root --mariadb-root-password \"${db_root_password}\" \"/home/frappe/frappe-bench/sites/${site_name}/private/backups/data.sql.gz\""

    site_cfg="${cdir}/data/sites/${site_name}/site_config.json"
    [[ -f "$site_cfg" ]] || log_err "site_config.json introuvable: $site_cfg"
    db_name="$(jq -r '.db_name // empty' "$site_cfg")"
    [[ -n "$db_name" ]] || log_err "db_name introuvable dans $site_cfg"

    log_info "Reset des mots de passe utilisateurs (hors Administrator/Guest)..."
    while IFS= read -r user_name; do
      [[ -z "$user_name" ]] && continue
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"${site_name}\" execute --args \"['${site_name}','${user_name}','${user_name}']\" frappe.commands.site.set_user_password"
    done < <(dc "$client" exec -T db sh -lc "mysql -uroot -p\"${db_root_password}\" --batch --skip-column-names \"${db_name}\"" < "${ROOT_DIR}/post_restore/get_user.sql")

    log_info "Sanitize email (greenmail)..."
    dc "$client" exec -T db sh -lc "mysql -uroot -p\"${db_root_password}\" \"${db_name}\"" < "${ROOT_DIR}/post_restore/sanitize.sql"

    log_info "Configuration post-restore..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"${site_name}\" set-admin-password admin"
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"${site_name}\" set-config developer_mode 1"
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"${site_name}\" enable-scheduler"
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"${site_name}\" migrate"

    restart_runtime_services "$client"
    log_ok "Restore terminé pour ${site_name}."
    ;;

  app-list)
    [[ -n "$client" ]] || usage
    site="$(get_env "$client" SITE_NAME)"
    log_info "Apps disponibles dans le bench (${client})..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && ls -1 apps"
    echo
    log_info "Apps installées sur le site ${site}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" list-apps"
    ;;

  app-get)
    [[ -n "$client" ]] || usage
    repo_url="${3:-}"
    branch="${4:-}"
    [[ -n "$repo_url" ]] || log_err "Usage: ./client app-get <client> <repo_url> [branch]"
    log_info "Récupération de l'app depuis ${repo_url}..."
    if [[ -n "$branch" ]]; then
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets --branch \"$branch\" \"$repo_url\""
    else
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets \"$repo_url\""
    fi
    log_ok "App récupérée."
    ;;

  app-install)
    [[ -n "$client" ]] || usage
    app_name="${3:-}"
    [[ -n "$app_name" ]] || log_err "Usage: ./client app-install <client> <app_name>"
    site="$(get_env "$client" SITE_NAME)"
    log_info "Installation de l'app ${app_name} sur ${site}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" install-app \"$app_name\""
    restart_runtime_services "$client"
    log_ok "App ${app_name} installée sur ${site}."
    ;;

  app-get-install)
    [[ -n "$client" ]] || usage
    repo_url="${3:-}"
    branch="${4:-}"
    app_name="${5:-}"
    [[ -n "$repo_url" ]] || log_err "Usage: ./client app-get-install <client> <repo_url> [branch] [app_name]"

    if [[ -n "$branch" ]]; then
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets --branch \"$branch\" \"$repo_url\""
    else
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench get-app --skip-assets \"$repo_url\""
    fi

    if [[ -z "$app_name" ]]; then
      app_name="$(basename "$repo_url")"
      app_name="${app_name%.git}"
    fi

    site="$(get_env "$client" SITE_NAME)"
    log_info "Installation de l'app ${app_name} sur ${site}..."
    bench_exec "$client" "cd /home/frappe/frappe-bench && bench --site \"$site\" install-app \"$app_name\""
    restart_runtime_services "$client"
    log_ok "App ${app_name} récupérée et installée."
    ;;

  bench-update)
    [[ -n "$client" ]] || usage
    bench_args=("${@:3}")
    has_reset=0
    has_no_backup=0
    for arg in "${bench_args[@]}"; do
      [[ "$arg" == "--reset" ]] && has_reset=1
      [[ "$arg" == "--no-backup" ]] && has_no_backup=1
    done
    (( has_reset == 1 )) || bench_args=(--reset "${bench_args[@]}")
    (( has_no_backup == 1 )) || bench_args=(--no-backup "${bench_args[@]}")
    log_info "Bench update pour ${client}: ${bench_args[*]}"
    seed_apps_from_git "$client"
    ensure_upstream_remotes "$client"
    cleanup_git_locks "$client"
    if ! bench_exec "$client" "cd /home/frappe/frappe-bench && bench update ${bench_args[*]}"; then
      log_warn "bench update a échoué, nettoyage des locks Git et retry..."
      cleanup_git_locks "$client"
      bench_exec "$client" "cd /home/frappe/frappe-bench && bench update ${bench_args[*]}"
    fi
    restart_runtime_services "$client"
    log_ok "Bench update terminé pour ${client}."
    ;;

  fix-perms)
    [[ -n "$client" ]] || usage
    log_info "Correction des permissions volumes pour ${client}..."
    fix_permissions "$client"
    log_ok "Permissions corrigées pour ${client}."
    ;;

  url)
    [[ -n "$client" ]] || usage
    ensure_client_exists "$client"
    port="$(get_env "$client" HTTP_PORT)"
    site="$(get_env "$client" SITE_NAME)"
    echo "Local:  http://localhost:${port}"
    echo "Site:   ${site}"
    ;;

  *)
    usage
    ;;
esac
